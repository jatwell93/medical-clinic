# Secrets — never commit (D-15)
.env

# Python
__pycache__/
*.pyc
*.pyo

# Jupyter
.ipynb_checkpoints/

# Local fallback data — large files, not in git (D-13)
data/local/

# Generated outputs — maps, report, PDF (regenerated on run)
outputs/

# Cache metadata — regenerable; keep the *.json response files (D-12)
# requests-cache filesystem backend stores responses in a subdirectory
# named after cache_name (e.g. data/cache/api_cache/), so match recursively.
data/cache/**/redirects.sqlite

