# Local Windows development — copy to .env and fill in your key.
# In Colab, this file is not used; add the key via the 🔑 sidebar (Colab Secrets).
# Get a key: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_PLACES_KEY=

# Phase 2 — SA1 boundary geometry (for catchment apportionment, D-01/D-02)
# Manual download from ABS digital boundary files:
#   https://www.abs.gov.au/statistics/standards/australian-statistical-geography-standard/asgs/edition-3-july-2021-june-2026/access-and-downloads/digital-boundary-files
# Download: SA1_2021_AUST_GDA2020.zip (~150 MB national)
# Then pre-filter to VIC-only GeoPackage (68% smaller — faster Colab upload):
#   python -c "import geopandas as gpd; gpd.read_file('data/local/SA1_2021_AUST_GDA2020.zip').query('STE_NAME21 == \"Victoria\"').to_file('data/local/SA1_2021_VIC_GDA2020.gpkg', driver='GPKG')"
# File name: SA1_2021_VIC_GDA2020.gpkg
# Place at: data/local/SA1_2021_VIC_GDA2020.gpkg
# (gitignored — large, immutable, not committed)

# Phase 2 — SA1 G01 total persons (for §2.3 apportionment weights, D-03)
# Manual download from ABS Census DataPacks (GCP — General Community Profile):
#   https://www.abs.gov.au/statistics/data-cubes/2021-census-data-packs
# Download: 2021_GCP_all_for_VIC_short-header.zip (~150 MB, VIC-only)
# Then extract just the SA1 G01 CSV (the zip contains every geography + every GCP table):
#   unzip -j "data/local/2021_GCP_all_for_VIC_short-header.zip" \
#     "2021 Census GCP All Geographies for VIC/SA1/VIC/2021Census_G01_VIC_SA1.csv" \
#     -d data/local/
# File name: 2021Census_G01_VIC_SA1.csv (~5 MB — 95% smaller than the national AUST file)
# Place at: data/local/2021Census_G01_VIC_SA1.csv
# (gitignored — manual download, same pattern as SA1 shapefile)
# Fallback: the national 2021Census_G01_AUST_SA1.csv (~100 MB) also works —
# the notebook tries the VIC file first, then AUST.

# Phase 3 — MBS SA3 Summary (for demand model, D-01)
# Manual download from Department of Health:
#   https://www.health.gov.au/resources/publications/medicare-quarterly-statistics-statistical-area-sa3-summary-march-quarter-2025-26
# File name: medicare-quarterly-statistics-statistical-area-sa3-summary-march-quarter-2025-26.xlsx
# Published: 25 May 2026. Contains GP Non-Referred Attendances by SA3.
# Place at: data/local/medicare-quarterly-statistics-statistical-area-sa3-summary-march-quarter-2025-26.xlsx
# (gitignored — large, immutable, not committed; same pattern as SA1 shapefile)

# Phase 3 — AIHW age-band GP attendance rates (for demand model, D-02)
# Manual download from AIHW:
#   https://www.aihw.gov.au/reports/primary-health-care/medicare-subsidised-gp-allied-health-specialist
# Click the "Data" tab, download aihw-phc-019-csv-file-2324-2425.zip, then EXTRACT the CSV.
# Updated 26 Mar 2026, covers 2017-18 to 2024-25.
# SA3 age bands: 0-24, 25-44, 45-64, 65+
# Pre-filter to VIC SA3 rows (88% smaller — faster Colab upload):
#   python -c "import pandas as pd; df=pd.read_csv('data/local/aihw-phc-19-csv_file_2425.csv',low_memory=False,on_bad_lines='skip'); df[(df.GeographicUnit=='SA3')&(df.StateTerritory=='Vic')].to_csv('data/local/aihw-phc-19-csv_file_2425_VIC_SA3.csv',index=False)"
# File name: aihw-phc-19-csv_file_2425_VIC_SA3.csv
# Place at: data/local/aihw-phc-19-csv_file_2425_VIC_SA3.csv
# (gitignored — manual download, same pattern as MBS SA3 file)
